---
// src/components/Hero.astro
import { siteConfig, stats } from '../data/site';
---

<section class="hero" id="home">
  <div class="hero-text">
    <span class="hero-tag">{siteConfig.tagline}</span>
    <h1>Expert skin care<br>you can <em>trust.</em></h1>
    <p class="hero-desc">
      Dr. Elara Voss offers evidence-based dermatological care — from medical
      skin conditions to advanced cosmetic treatments — tailored to your skin's
      unique needs.
    </p>
    <div class="hero-actions">
      <a href="#booking" class="btn-primary">Book a Consultation</a>
      <a href="#services" class="btn-secondary">View Services</a>
    </div>
  </div>

  <div class="hero-visual">
    <div class="hero-card">
      <div class="hero-img-placeholder">[ Doctor Photo ]</div>
      <div class="hero-card-body">
        <div>
          <h3>Dr. Elara Voss</h3>
          <p>MBChB · FC Derm (SA) · Johannesburg</p>
        </div>
        <div class="hero-badge">Accepting Patients</div>
      </div>
      <div class="hero-stats">
        {stats.map(stat => (
          <div class="stat-box">
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 8rem 4rem 4rem;
    gap: 4rem;
  }

  .hero-text { animation: fadeUp 0.8s 0.2s ease both; }

  .hero-tag {
    display: inline-block;
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.35rem 0.9rem;
    border-radius: 2px;
    margin-bottom: 1.8rem;
  }

  .hero h1 {
    font-family: var(--serif);
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    font-weight: 300;
    line-height: 1.15;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }
  .hero h1 em { font-style: italic; color: var(--accent); }

  .hero-desc {
    font-size: 1rem;
    color: var(--ink-light);
    max-width: 440px;
    margin-bottom: 2.5rem;
    line-height: 1.8;
    font-weight: 300;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* ── Card ── */
  .hero-visual {
    animation: fadeUp 0.8s 0.4s ease both;
    position: relative;
  }

  .hero-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.07);
  }

  .hero-img-placeholder {
    width: 100%;
    height: 380px;
    background: linear-gradient(145deg, var(--accent-pale) 0%, #D4EAE7 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--accent);
    letter-spacing: 0.05em;
    position: relative;
    overflow: hidden;
  }
  .hero-img-placeholder::before {
    content: '';
    position: absolute;
    width: 240px; height: 240px;
    border-radius: 50%;
    background: rgba(46,110,101,0.08);
    top: -60px; right: -60px;
  }
  .hero-img-placeholder::after {
    content: '';
    position: absolute;
    width: 160px; height: 160px;
    border-radius: 50%;
    background: rgba(46,110,101,0.06);
    bottom: -40px; left: -40px;
  }

  .hero-card-body {
    padding: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border);
  }
  .hero-card-body h3 {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 500;
  }
  .hero-card-body p {
    font-size: 0.8rem;
    color: var(--ink-light);
    letter-spacing: 0.04em;
  }

  .hero-badge {
    background: var(--accent-pale);
    color: var(--accent);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.4rem 0.8rem;
    border-radius: 2px;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-top: none;
    border-radius: 0 0 4px 4px;
    overflow: hidden;
  }
  .stat-box {
    background: var(--white);
    padding: 1.2rem 1rem;
    text-align: center;
  }
  .stat-box strong {
    display: block;
    font-family: var(--serif);
    font-size: 1.6rem;
    font-weight: 500;
    color: var(--accent);
  }
  .stat-box span {
    font-size: 0.72rem;
    color: var(--ink-light);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 7rem 2rem 3rem;
    }
    .hero-visual { display: none; }
  }
</style>
