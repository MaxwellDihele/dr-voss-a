---
// src/components/About.astro
import { about } from '../data/site';
---

<section id="about">
  <div class="about-visual">
    <img src="/images/dr-voss.png" alt="Dr. Elara Voss" class="about-img" />
    <div class="about-accent-box">
      <strong>{about.yearsOfPractice}</strong>
      <span>Years of Practice</span>
    </div>
  </div>

  <div class="about-text">
    <p class="section-tag">About the Doctor</p>
    <h2 class="section-title">{about.name}</h2>

    {about.bio.map((para, i) => (
      <p class={i === 0 ? 'section-sub' : 'bio-extra'}>{para}</p>
    ))}

    <div class="credentials">
      {about.credentials.map(cred => (
        <div class="credential">
          <div class="credential-dot"></div>
          <span>{cred}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .about-visual { position: relative; }
  
  .about-img {
  width: 100%;
  height: 480px;
  object-fit: cover;
  object-position: center top;
  border-radius: 4px;
  border: 1px solid var(--border);
  display: block;
}

  .about-accent-box {
    position: absolute;
    bottom: -1.5rem; right: -1.5rem;
    background: var(--accent);
    color: var(--white);
    padding: 1.5rem;
    border-radius: 4px;
    width: 170px;
    text-align: center;
  }
  .about-accent-box strong {
    display: block;
    font-family: var(--serif);
    font-size: 2rem;
  }
  .about-accent-box span {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  .bio-extra {
    font-size: 0.88rem;
    color: var(--ink-light);
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 1.5rem;
  }

  .credentials {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .credential {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.88rem;
    color: var(--ink-light);
  }

  .credential-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    margin-top: 0.55rem;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    #about { grid-template-columns: 1fr; }
    .about-visual { display: none; }
  }
</style>
